# ============================================================
# 多智能体系统环境变量配置模板
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# 注意：.env 已被 .gitignore 排除，切勿将真实密钥提交至版本库
# ============================================================

# DeepSeek API（OpenAI 兼容接口，用于调度主管和回答Agent）
OPENAI_API_KEY=sk-your-deepseek-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

# LLM 容错（重试/熔断/降级/成本熔断）
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_RECOVERY_TIMEOUT=60
LLM_TOKEN_BUDGET_PER_MINUTE=0
FALLBACK_MODEL_NAME=
FALLBACK_OPENAI_BASE_URL=

# Tavily 联网搜索
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# 本地Ollama模型（用于视觉识别和RAG嵌入）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=qwen3-vl:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# 向量嵌入维度（nomic-embed-text 输出 768 维）
EMBEDDING_DIM=768

# PostgreSQL 数据库连接（Docker Compose 中由 db 服务提供）
DATABASE_URL=postgresql://agent:agent-local@localhost:5433/agent
PG_POOL_MIN_SIZE=2
PG_POOL_MAX_SIZE=10

# JWT 认证
# 生产环境必须替换为强随机密钥！生成方式：python -c "import secrets; print(secrets.token_hex(32))"
# 若保留占位符或长度不足32字符，应用将拒绝启动
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# CORS 允许的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# 文件上传限制（MB）
MAX_UPLOAD_SIZE_MB=20

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=text

# 可观测性（OpenTelemetry，可选启用）
OTEL_ENABLED=False
OTEL_SERVICE_NAME=multi-agent-system
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ============================================================
# 分布式部署配置（gunicorn 多 worker + nginx 负载均衡 + Redis 缓存）
# ============================================================

# Gunicorn 进程管理配置
# worker 进程数，默认 CPU核数*2+1，生产建议 4-8
WORKERS=4
# 服务绑定地址和端口，容器内默认 0.0.0.0:8000
BIND=0.0.0.0:8000
# 请求超时时间（秒），AI 对话可能较慢，建议不低于 120
TIMEOUT=120
# 优雅关闭等待时间（秒）
GRACEFUL_TIMEOUT=30
# keepalive 连接保持时间（秒）
KEEPALIVE=5
# 每个 worker 处理的最大请求数（防止内存泄漏，处理后自动重启）
MAX_REQUESTS=1000
# 最大请求数随机抖动（避免所有 worker 同时重启）
MAX_REQUESTS_JITTER=50
# 每个 worker 最大并发连接数
WORKER_CONNECTIONS=1000
# 日志级别（debug/info/warning/error/critical）
LOG_LEVEL=info

# 分布式实例标识（用于多实例日志区分与追踪）
# 当前实例的 worker 数量，用于日志标识
WORKER_COUNT=1
# 实例唯一标识，留空则自动生成 hostname:pid
INSTANCE_ID=

# Redis 分布式缓存配置
# 是否启用 Redis 缓存（多实例部署必须启用以共享会话状态）
REDIS_ENABLED=true
# Redis 连接地址，Docker Compose 中使用服务名 redis
REDIS_URL=redis://redis:6379/0
